{
  "prompts_dir": "/home/mjlockboxsocial/vibepilot/prompts",
  "database": {
    "type": "supabase",
    "url_env": "SUPABASE_URL",
    "key_env": "SUPABASE_SERVICE_KEY"
  },
  "vault": {
    "key_env": "VAULT_KEY",
    "table": "secrets_vault",
    "cache_ttl_seconds": 300
  },
  "git": {
    "host": "github",
    "repo_env": "GITHUB_REPO",
    "token_env": "GITHUB_TOKEN",
    "protected_branches": ["main", "master", "research-considerations"]
  },
  "runtime": {
    "max_concurrent_per_module": 8,
    "max_concurrent_total": 160,
    "event_poll_interval_ms": 1000,
    "agent_timeout_seconds": 300,
    "max_tool_turns": 10,
    "event_query_limit": 10
  },
  "recovery": {
    "heartbeat_interval_seconds": 30,
    "orphan_threshold_seconds": 300,
    "stuck_dependency_threshold_hours": 2,
    "human_approval_timeout_days": 3,
    "max_task_attempts": 3,
    "model_failure_threshold": 3,
    "usage_threshold_pct": 80,
    "auto_bench_on_failures": true,
    "auto_restore_after_cooldown": true
  },
  "defaults": {
    "throttle_behavior": "slow_down",
    "buffer_pct": 80,
    "spacing_min_seconds": 1,
    "cooldown_minutes": 30
  },
  "concurrency": {
    "limits": {
      "opencode": 5,
      "kimi": 5,
      "courier": 3,
      "gemini-api": 10,
      "deepseek-api": 5
    },
    "default_limit": 3
  },
  "security": {
    "leak_detection_enabled": true,
    "http_allowlist": [
      "api.supabase.co",
      "api.github.com",
      "github.com",
      "api.anthropic.com",
      "api.openai.com",
      "generativelanguage.googleapis.com",
      "api.deepseek.com"
    ]
  },
  "events": {
    "task_statuses_available": ["available"],
    "task_statuses_review": ["review"],
    "task_statuses_completed": ["testing", "approval"],
    "plan_statuses_draft": ["draft"],
    "plan_statuses_review": ["review"],
    "plan_statuses_council": ["council_review", "revision_needed"],
    "plan_statuses_pending_human": ["pending_human"],
    "plan_statuses_approved": ["approved"],
    "maintenance_status": "pending",
    "test_results_status": "pending_review"
  },
  "sandbox": {
    "default_test_command": "npm test",
    "timeout_seconds": 60,
    "temp_dir": ""
  },
  "web_tools": {
    "search_url": "https://api.duckduckgo.com/",
    "user_agent": "Mozilla/5.0 (compatible; VibePilot/2.0)",
    "max_fetch_length": 10000,
    "max_related_topics": 5,
    "timeout_seconds": 30
  }
}
