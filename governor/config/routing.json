{
  "$schema": "./schemas/routing.schema.json",
  "version": "1.0",
  "description": "Routing configuration. All priority and restrictions are configurable. Nothing hardcoded in code.",
  "default_strategy": "default",
  "strategies": {
    "default": {
      "description": "External first if task allows, then internal",
      "priority": [
        "external",
        "internal"
      ]
    },
    "internal_only": {
      "description": "Never use external platforms",
      "priority": [
        "internal"
      ]
    },
    "external_only": {
      "description": "Only use external platforms",
      "priority": [
        "external"
      ]
    },
    "free_cascade": {
      "description": "Cascade through free API models in priority order. Used when agent has no model pin.",
      "priority": [
        "gemini-2.5-flash-lite",
        "gemini-3.1-flash-lite-preview",
        "gemini-3-flash-preview",
        "gemini-2.5-flash",
        "qwen/qwen3-next-80b-a3b-instruct:free",
        "qwen/qwen3-coder:free",
        "openrouter/free",
        "minimax/minimax-m2.5",
        "meta-llama/llama-4-scout-17b-16e-instruct",
        "llama-3.3-70b-versatile",
        "groq/compound",
        "openai/gpt-oss-120b",
        "groq/compound-mini",
        "llama-3.1-8b-instant",
        "meta/llama-3.3-70b-instruct",
        "google/gemma-4-26b-a4b-it:free",
        "google/gemma-3-27b-it:free",
        "deepseek-chat",
        "glm-5"
      ]
    }
  },
  "agent_restrictions": {
    "internal_only": [
      "planner",
      "supervisor",
      "council",
      "orchestrator",
      "maintenance",
      "watcher",
      "tester"
    ],
    "default": [
      "consultant",
      "researcher",
      "courier",
      "task_runner"
    ]
  },
  "destination_categories": {
    "external": {
      "description": "Web platforms accessed by couriers",
      "check_field": "type",
      "check_values": [
        "web"
      ]
    },
    "internal": {
      "description": "CLI and API destinations",
      "check_field": "type",
      "check_values": [
        "cli",
        "api"
      ]
    }
  },
  "selection_criteria": {
    "status": "active",
    "not_at_limit": true,
    "prefer_learned_best": true
  },
  "fallback": {
    "on_category_unavailable": "try_next_priority",
    "on_all_unavailable": "pause_and_alert"
  }
}
