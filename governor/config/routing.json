{
  "$schema": "./schemas/routing.schema.json",
  "version": "1.0",
  "description": "Routing configuration. All priority and restrictions are configurable. Nothing hardcoded in code.",
  "default_strategy": "default",
  "strategies": {
    "default": {
      "description": "External first if task allows, then internal",
      "priority": [
        "external",
        "internal"
      ]
    },
    "internal_only": {
      "description": "Never use external platforms",
      "priority": [
        "internal"
      ]
    },
    "external_only": {
      "description": "Only use external platforms",
      "priority": [
        "external"
      ]
    },
    "free_cascade": {
      "description": "Cascade through free API models in priority order. Used when agent has no model pin.",
      "priority": [
        "glm-5",
        "nvidia/llama-3.1-nemotron-ultra-253b-v1",
        "meta/llama-3.3-70b-instruct",
        "qwen/qwen3-32b",
        "moonshotai/kimi-k2-instruct",
        "llama-3.3-70b-versatile",
        "llama-3.1-8b-instant",
        "gemini-2.5-flash",
        "deepseek-chat"
      ]
    }
  },
  "agent_restrictions": {
    "internal_only": [
      "planner",
      "supervisor",
      "council",
      "orchestrator",
      "maintenance",
      "watcher",
      "tester"
    ],
    "default": [
      "consultant",
      "researcher",
      "courier",
      "task_runner"
    ]
  },
  "destination_categories": {
    "external": {
      "description": "Web platforms accessed by couriers",
      "check_field": "type",
      "check_values": [
        "web"
      ]
    },
    "internal": {
      "description": "CLI and API destinations",
      "check_field": "type",
      "check_values": [
        "cli",
        "api"
      ]
    }
  },
  "selection_criteria": {
    "status": "active",
    "not_at_limit": true,
    "prefer_learned_best": true
  },
  "fallback": {
    "on_category_unavailable": "try_next_priority",
    "on_all_unavailable": "pause_and_alert"
  }
}