{
  "tools": {
    "git_create_branch": {
      "description": "Create a new git branch",
      "parameters": {
        "name": {"type": "string", "required": true}
      },
      "security_level": "write",
      "implementation": "gitree"
    },
    "git_read_branch": {
      "description": "Read files from a branch",
      "parameters": {
        "branch": {"type": "string", "required": true}
      },
      "security_level": "read",
      "implementation": "gitree"
    },
    "git_commit": {
      "description": "Commit output to a branch",
      "parameters": {
        "branch": {"type": "string", "required": true},
        "output": {"type": "object", "required": true}
      },
      "security_level": "write",
      "implementation": "gitree"
    },
    "git_merge": {
      "description": "Merge source branch into target branch",
      "parameters": {
        "source": {"type": "string", "required": true},
        "target": {"type": "string", "required": true}
      },
      "security_level": "write",
      "implementation": "gitree"
    },
    "git_delete_branch": {
      "description": "Delete a git branch",
      "parameters": {
        "name": {"type": "string", "required": true}
      },
      "security_level": "write",
      "implementation": "gitree"
    },
    "git_clear_branch": {
      "description": "Clear all files from a branch for retry",
      "parameters": {
        "name": {"type": "string", "required": true}
      },
      "security_level": "write",
      "implementation": "gitree"
    },
    "db_query": {
      "description": "Query database table",
      "parameters": {
        "table": {"type": "string", "required": true},
        "columns": {"type": "array", "required": false},
        "where": {"type": "object", "required": false},
        "limit": {"type": "integer", "required": false}
      },
      "security_level": "read",
      "implementation": "db"
    },
    "db_update": {
      "description": "Update database record",
      "parameters": {
        "table": {"type": "string", "required": true},
        "id": {"type": "string", "required": true},
        "data": {"type": "object", "required": true}
      },
      "security_level": "write",
      "implementation": "db"
    },
    "db_rpc": {
      "description": "Call database RPC function",
      "parameters": {
        "name": {"type": "string", "required": true},
        "params": {"type": "object", "required": false}
      },
      "security_level": "write",
      "implementation": "db"
    },
    "command_maintenance": {
      "description": "Queue a maintenance command",
      "parameters": {
        "command": {"type": "string", "required": true},
        "params": {"type": "object", "required": false}
      },
      "security_level": "write",
      "implementation": "db"
    },
    "file_read": {
      "description": "Read file from repository",
      "parameters": {
        "path": {"type": "string", "required": true}
      },
      "security_level": "read",
      "implementation": "file"
    },
    "file_write": {
      "description": "Write file to repository",
      "parameters": {
        "path": {"type": "string", "required": true},
        "content": {"type": "string", "required": true}
      },
      "security_level": "write",
      "implementation": "file"
    },
    "file_delete": {
      "description": "Delete file from repository",
      "parameters": {
        "path": {"type": "string", "required": true}
      },
      "security_level": "write",
      "implementation": "file"
    },
    "vault_get": {
      "description": "Get secret from vault (returns existence only, not value)",
      "parameters": {
        "key": {"type": "string", "required": true}
      },
      "security_level": "secret",
      "implementation": "vault"
    },
    "web_search": {
      "description": "Search the web using DuckDuckGo",
      "parameters": {
        "query": {"type": "string", "required": true}
      },
      "security_level": "read",
      "implementation": "web"
    },
    "web_fetch": {
      "description": "Fetch content from a URL",
      "parameters": {
        "url": {"type": "string", "required": true}
      },
      "security_level": "read",
      "implementation": "web"
    },
    "sandbox_test": {
      "description": "Run code in sandbox for testing",
      "parameters": {
        "files": {"type": "array", "required": true},
        "test_command": {"type": "string", "required": false}
      },
      "security_level": "execute",
      "implementation": "sandbox"
    },
    "run_lint": {
      "description": "Run linter on codebase",
      "parameters": {
        "path": {"type": "string", "required": false}
      },
      "security_level": "execute",
      "implementation": "sandbox"
    },
    "run_typecheck": {
      "description": "Run type checker on codebase",
      "parameters": {
        "path": {"type": "string", "required": false}
      },
      "security_level": "execute",
      "implementation": "sandbox"
    }
  }
}
