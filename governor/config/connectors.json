{
  "$schema": "./schemas/destinations.schema.json",
  "version": "2.0",
  "description": "Destination configurations with native tool capabilities. CLI destinations provide tools, API destinations do other.",
  "destinations": [
    {
      "id": "opencode",
      "name": "OpenCode CLI",
      "type": "cli",
      "status": "inactive",
      "command": "opencode",
      "cli_args": [
        "run",
        "--format",
        "json"
      ],
      "timeout_seconds": 300,
      "provides_tools": [
        "read",
        "write",
        "bash",
        "webfetch",
        "edit",
        "glob",
        "grep"
      ],
      "notes": "Uses ~700MB RAM per session. Consider Kilo for lower memory footprint."
    },
    {
      "id": "claude-code",
      "name": "Claude Code CLI",
      "type": "cli",
      "status": "inactive",
      "command": "claude",
      "cli_args": [
        "-p",
        "--output-format",
        "json"
      ],
      "timeout_seconds": 300,
      "provides_tools": [
        "read",
        "write",
        "bash",
        "webfetch",
        "edit",
        "glob",
        "grep"
      ],
      "notes": "Claude Code CLI. Inactive - auth broken after key rotation."
    },
    {
      "id": "hermes",
      "name": "Hermes Agent",
      "type": "cli",
      "status": "active",
      "command": "hermes",
      "cli_args": [
        "chat",
        "-q",
        "{PROMPT}",
        "-Q",
        "-t",
        "terminal,file",
        "--yolo",
        "--max-turns",
        "50"
      ],
      "timeout_seconds": 300,
      "provides_tools": [
        "read",
        "write",
        "bash",
        "webfetch",
        "edit",
        "glob",
        "grep",
        "search",
        "browser",
        "terminal",
        "file"
      ],
      "notes": "Hermes Agent CLI. For executor tasks that need tools. GLM-5 via Z.AI."
    },
    {
      "id": "kimi",
      "name": "Kimi CLI",
      "type": "cli",
      "status": "inactive",
      "command": "kimi",
      "cli_args": [
        "run",
        "--format",
        "json"
      ],
      "timeout_seconds": 300,
      "provides_tools": [
        "read",
        "write",
        "bash",
        "websearch",
        "webfetch"
      ],
      "notes": "Web search enabled"
    },
    {
      "id": "gemini-api-courier",
      "name": "Gemini API (Courier Project)",
      "type": "api",
      "status": "active",
      "provider": "google",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta/models",
      "api_key_ref": "GEMINI_COURIER_KEY",
      "models_available": [
        "gemini-2.5-flash-lite"
      ],
      "provides_tools": [],
      "rate_limits": {
        "requests_per_minute": 15,
        "requests_per_day": 1500
      },
      "notes": "Stable workhorse for high-throughput courier tasks. 1000 RPD free-tier limit. Safest choice."
    },
    {
      "id": "gemini-api-researcher",
      "name": "Gemini API (Researcher Project)",
      "type": "api",
      "status": "active",
      "provider": "google",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta/models",
      "api_key_ref": "GEMINI_RESEARCHER_KEY",
      "models_available": [
        "gemini-3.1-flash-lite-preview"
      ],
      "provides_tools": [],
      "rate_limits": {
        "requests_per_minute": 15,
        "requests_per_day": 1500
      },
      "notes": "Best intelligence for daily system researcher. Smarter than 2.5 but in preview mode."
    },
    {
      "id": "gemini-api-visual",
      "name": "Gemini API (Visual Tester / Brain)",
