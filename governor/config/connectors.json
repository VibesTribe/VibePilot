        "requests_per_day": 1500
      },
      "notes": "Best available on free tier for code/visual QA. 3.1-pro-preview requires billing. 3-flash-preview is free and capable."
    },
    {
      "id": "gemini-api-general",
      "name": "Gemini API (General / Legacy Fallback)",
      "type": "api",
      "status": "active",
      "provider": "google",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta/models",
