{
  "$schema": "./schemas/destinations.schema.json",
  "version": "2.0",
  "description": "Destination configurations with native tool capabilities. CLI destinations provide tools, API destinations do other.",
  "destinations": [
    {
      "id": "opencode",
      "name": "OpenCode CLI",
      "type": "cli",
      "status": "inactive",
      "command": "opencode",
      "cli_args": ["run", "--format", "json"],
      "timeout_seconds": 300,
      "provides_tools": ["read", "write", "bash", "webfetch", "edit", "glob", "grep"],
      "notes": "Uses ~700MB RAM per session. Consider Kilo for lower memory footprint."
    },
    {
      "id": "kilo",
      "name": "Kilo CLI",
      "type": "cli",
      "status": "active",
      "command": "kilo",
      "cli_args": ["run", "-m", "zhipuai-coding-plan/glm-5"],
      "timeout_seconds": 300,
      "provides_tools": ["read", "write", "bash", "webfetch", "edit", "glob", "grep"],
      "notes": "Fork of OpenCode with ~350MB RAM (50% less). Uses GLM-5 via Z.ai subscription."
    },
    {
      "id": "kimi",
      "name": "Kimi CLI",
      "type": "cli",
      "status": "inactive",
      "command": "kimi",
      "cli_args": ["run", "--format", "json"],
      "timeout_seconds": 300,
      "provides_tools": ["read", "write", "bash", "websearch", "webfetch"],
      "notes": "Web search enabled"
    },
    {
      "id": "gemini-api",
      "name": "Gemini API",
      "type": "api",
      "status": "active",
      "provider": "google",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta/models",
      "api_key_ref": "GEMINI_API_KEY",
      "models_available": ["gemini-2.0-flash", "gemini-1.5-pro"],
      "provides_tools": []
    },
    {
      "id": "deepseek-api",
      "name": "DeepSeek API",
      "type": "api",
      "status": "inactive",
