      "api_key_ref": "DEEPSEEK_API_KEY",
      "models_available": ["deepseek-chat", "deepseek-reasoner"],
      "provides_tools": []
    },
    {
      "id": "groq-api",
      "name": "Groq Cloud API",
      "type": "api",
      "status": "pending_key",
      "provider": "groq",
      "endpoint": "https://api.groq.com/openai/v1",
      "api_key_ref": "GROQ_API_KEY",
      "models_available": ["llama-3.3-70b-versatile", "llama-3.1-8b-instant", "qwen3-32b"],
      "provides_tools": [],
      "notes": "Need to add GROQ_API_KEY to vault"
    },
    {
      "id": "openrouter-api",
      "name": "OpenRouter API",
      "type": "api",
      "status": "emergency_fallback",
