        "-p",
        "--output-format",
        "json"
      ],
      "timeout_seconds": 300,
      "provides_tools": [
        "read",
        "write",
        "bash",
        "webfetch",
        "edit",
        "glob",
        "grep"
      ],
      "notes": "Claude Code CLI. Inactive - auth broken after key rotation."
