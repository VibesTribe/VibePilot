      "models_available": ["deepseek/deepseek-r1:free", "google/gemini-2.5-flash-preview:free"],
      "provides_tools": [],
      "notes": "EMERGENCY ONLY. Always use :free suffix. Set $0 spend limit in dashboard. Free models can fall back to paid without warning."
    },
    {
      "id": "chatgpt-web",
      "name": "ChatGPT Web",
