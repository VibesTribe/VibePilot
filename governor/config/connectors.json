  "destinations": [
    {
      "id": "opencode",
      "name": "OpenCode CLI",
      "type": "cli",
      "status": "inactive",
      "command": "opencode",
      "cli_args": ["run", "--format", "json"],
      "timeout_seconds": 300,
      "provides_tools": ["read", "write", "bash", "webfetch", "edit", "glob", "grep"],
      "notes": "Uses ~700MB RAM per session. Consider Kilo for lower memory footprint."
    },
    {
      "id": "claude-code",
