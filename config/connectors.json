{
  "$schema": "./schemas/destinations.schema.json",
  "version": "3.0",
  "description": "API and web connectors. To add a provider: add destination object, set status=active, reference api_key_ref. No code changes.",
  "destinations": [
    {
      "id": "claude-code",
      "name": "Claude Code CLI",
      "type": "cli",
      "status": "active",
      "command": "claude",
      "cli_args": ["-p", "--output-format", "json"],
      "timeout_seconds": 300,
      "provides_tools": ["read", "write", "bash", "webfetch", "edit", "glob", "grep"],
      "notes": "Claude Code CLI. Currently using GLM-5.1 via ZAI until May 1."
    },
    {
      "id": "gemini-api",
      "name": "Gemini API",
      "type": "api",
      "status": "active",
      "provider": "google",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta/models",
      "api_key_ref": "GEMINI_API_KEY",
      "models_available": ["gemini-2.5-flash", "gemini-2.0-flash"],
      "provides_tools": [],
      "notes": "Primary API. Free tier. 15 RPM, 1500 RPD."
    },
    {
      "id": "groq-api",
      "name": "Groq Cloud API",
      "type": "api",
      "status": "active",
      "provider": "groq",
      "endpoint": "https://api.groq.com/openai/v1",
      "api_key_ref": "GROQ_API_KEY",
      "models_available": ["llama-3.1-8b-instant", "compound", "qwen3-32b", "llama-4-scout"],
      "provides_tools": [],
      "notes": "Fast inference. 30 RPM free tier. Key in .env."
    },
    {
      "id": "nvidia-api",
      "name": "NVIDIA NIM API",
      "type": "api",
      "status": "active",
      "provider": "nvidia",
      "endpoint": "https://integrate.api.nvidia.com/v1",
      "api_key_ref": "NVIDIA_API_KEY",
      "models_available": ["google/gemma-3-4b-it", "meta/llama-3.3-70b-instruct", "deepseek-ai/deepseek-v3.2", "google/gemma-4-31b-it", "qwen/qwen3-coder-480b-a35b-instruct"],
      "provides_tools": [],
      "notes": "131 models available. 12-month free tier. Verified working Apr 15."
    },
    {
      "id": "openrouter-api",
      "name": "OpenRouter API",
      "type": "api",
      "status": "active",
      "provider": "openrouter",
      "endpoint": "https://openrouter.ai/api/v1",
      "api_key_ref": "OPENROUTER_API_KEY",
      "models_available": ["google/gemma-4-31b-it:free", "nvidia/nemotron-3-super-120b-a12b:free", "qwen/qwen3-coder-480b-a35b:free"],
      "provides_tools": [],
      "notes": "Free models only (:free suffix). Balance -17c but free models still work. Last resort."
    },
    {
      "id": "opencode",
      "name": "OpenCode CLI",
      "type": "cli",
      "status": "inactive",
      "command": "opencode",
      "cli_args": ["run", "--format", "json"],
      "timeout_seconds": 300,
      "provides_tools": ["read", "write", "bash", "webfetch", "edit", "glob", "grep"],
      "notes": "Inactive. Uses ~700MB RAM per session."
    },
    {
      "id": "kimi",
      "name": "Kimi CLI",
      "type": "cli",
      "status": "inactive",
      "command": "kimi",
      "cli_args": ["run", "--format", "json"],
      "timeout_seconds": 300,
      "provides_tools": ["read", "write", "bash", "websearch", "webfetch"],
      "notes": "Inactive. Subscription ended."
    },
    {
      "id": "deepseek-api",
      "name": "DeepSeek API",
      "type": "api",
      "status": "inactive",
      "provider": "deepseek",
      "endpoint": "https://api.deepseek.com",
      "api_key_ref": "DEEPSEEK_API_KEY",
      "models_available": ["deepseek-chat", "deepseek-reasoner"],
      "provides_tools": [],
      "notes": "Inactive. Paid API. Use DeepSeek via NVIDIA NIM instead (free)."
    },
    {
      "id": "gemini-web",
      "name": "Gemini Web",
      "type": "web",
      "status": "active",
      "url": "https://gemini.google.com",
      "provider": "google",
      "requires_auth": "browser_login",
      "models_available": ["gemini-2.5-flash", "gemini-2.5-pro"],
      "provides_tools": [],
      "notes": "Courier destination. Chrome CDP auto-login. 1M tokens/day."
    },
    {
      "id": "deepseek-web",
      "name": "DeepSeek Web",
      "type": "web",
      "status": "active",
      "url": "https://chat.deepseek.com",
      "provider": "deepseek",
      "requires_auth": "optional",
      "models_available": ["deepseek-chat", "deepseek-r1"],
      "provides_tools": [],
      "notes": "Courier destination. CloudFront blocks headless. Use CDP Chrome."
    },
    {
      "id": "chatgpt-web",
      "name": "ChatGPT Web",
      "type": "web",
      "status": "inactive",
      "url": "https://chatgpt.com",
      "provider": "openai",
      "requires_auth": "browser_login",
      "models_available": ["chatgpt-4o-mini"],
      "provides_tools": [],
      "notes": "Cloudflare blocks headless. CDP may work if logged in."
    },
    {
      "id": "huggingchat-web",
      "name": "HuggingChat",
      "type": "web",
      "status": "active",
      "url": "https://huggingface.co/chat",
      "provider": "huggingface",
      "requires_auth": "none",
      "models_available": ["various-opensource"],
      "provides_tools": [],
      "notes": "Courier destination. No login needed. Works in headless."
    },
    {
      "id": "qwen-web",
      "name": "Qwen Web",
      "type": "web",
      "status": "active",
      "url": "https://qwen.ai",
      "provider": "alibaba",
      "requires_auth": "none",
      "models_available": ["qwen-3", "qwen-2.5"],
      "provides_tools": [],
      "notes": "Courier destination. Works without login."
    },
    {
      "id": "mistral-web",
      "name": "Mistral Le Chat",
      "type": "web",
      "status": "active",
      "url": "https://chat.mistral.ai",
      "provider": "mistral",
      "requires_auth": "browser_login",
      "models_available": ["mistral-large", "codestral"],
      "provides_tools": [],
      "notes": "Courier destination. Free tier."
    }
  ]
}
