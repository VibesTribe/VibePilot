{
  "version": "1.0",
  "description": "All available skills in VibePilot. Add/remove skills here. Agents reference these by ID.",
  "skills": [
    {
      "id": "route",
      "name": "Route Task",
      "category": "core",
      "description": "Route task to appropriate runner based on real-time availability AND historical performance. Tracks success/failure rates, failure reasons, model strengths/weaknesses. Tracks token burn even on failures. Escalates after max reassignments.",
      "runner": "runners/route.py",
      "inputs": ["task_packet", "suggested_runner", "reassignment_count", "cumulative_cost"],
      "outputs": ["assigned_runner", "reason", "paused", "alert", "escalation"],
      "tracks": {
        "per_model": ["success_rate", "failure_reasons", "avg_duration", "task_types_succeeded", "task_types_failed"],
        "per_platform": ["availability", "limit_status", "downtime_events"],
        "failure_categories": ["resource_limit_exceeded", "platform_down", "timeout", "output_mismatch", "test_failed", "no_result_returned"],
        "costs": ["tokens_per_attempt", "virtual_cost_per_attempt", "cumulative_task_cost"]
      },
      "routing_logic": {
        "factors": ["current_availability", "historical_success_rate", "task_type_match", "platform_limits", "subscription_status", "cost_efficiency"],
        "pause_at_percent": 80,
        "fallback_chain": {
          "courier_unavailable": "internal_cli",
          "internal_cli_unavailable": "internal_api",
          "all_unavailable": "pause_and_alert"
        },
        "learning": "prefer models with high success rate for similar task types"
      },
      "escalation_rules": {
        "max_reassignments": 3,
        "after_max_failures": {
          "output_mismatch": {
            "action": "return_to_planner",
            "diagnosis": "Prompt unclear or task ambiguous",
            "planner_decides": ["reprompt_with_clarification", "split_task", "flag_prd_issue"]
          },
          "timeout": {
            "action": "go_internal_or_split",
            "diagnosis": "Task too large or model too slow",
            "options": ["use_kimi_cli", "split_into_smaller_tasks"]
          },
          "resource_limit": {
            "action": "switch_platform",
            "diagnosis": "Platform capacity exhausted",
            "options": ["different_courier_platform", "internal"]
          },
          "test_failed": {
            "action": "council_review_approach",
            "diagnosis": "Implementation approach may be wrong",
            "council_decides": ["different_approach", "different_model_type", "split_task"]
          },
          "repeated_same_failure": {
            "action": "planner_diagnosis",
            "diagnosis": "Systemic issue - either prompt, task, or approach",
            "planner_analyzes": ["Is task well-defined?", "Is prompt clear?", "Is approach viable?", "Is PRD ambiguous?"],
            "if_prd_issue": "back_to_consultant"
          }
        },
        "human_only_if": ["prd_fundamentally_wrong", "credit_subscription_decision", "visual_ui_ux_decision"],
        "human_updates": ["daily_briefing_from_vibes", "research_suggestions", "roi_summary"],
        "track_virtual_cost": true,
        "compare_to_api_cost": true
      },
      "ok_probe": {
        "command": "python runners/route.py --probe",
        "timeout_seconds": 5
      }
    },
    {
      "id": "consult",
      "name": "Consult",
      "category": "governance",
      "description": "Produce ZERO AMBIGUITY PRD. Every gap downstream agents fill with blind guesses. Eliminate all vagueness before planning.",
      "runner": "runners/consult.py",
      "inputs": ["conversation", "context"],
      "outputs": ["prd", "clarifications", "questions_answered"],
      "ok_probe": {
        "command": "python runners/consult.py --probe",
        "timeout_seconds": 10
      }
    },
    {
      "id": "plan",
      "name": "Plan",
      "category": "governance",
      "description": "Break down PRD into executable tasks with dependencies and confidence scores",
      "runner": "runners/plan.py",
      "inputs": ["prd", "codebase_context"],
      "outputs": ["tasks", "dependency_graph"],
      "ok_probe": {
        "command": "python runners/plan.py --probe",
        "timeout_seconds": 10
      }
    },
    {
      "id": "council_review",
      "name": "Council Review",
      "category": "governance",
      "description": "Multi-model review: GLM-5, Kimi, Gemini review independently. Different models catch different things. Rejects include WHY + WHAT TO FIX.",
      "runner": "runners/council.py",
      "inputs": ["task", "proposed_solution", "prd"],
      "outputs": ["verdict", "reviews_by_model", "required_changes", "rejection_reason"],
      "council_models": ["glm5", "kimi", "gemini"],
      "fallback_single_model_hats": ["architect", "security", "maintenance"],
      "ok_probe": {
        "command": "python runners/council.py --probe",
        "timeout_seconds": 15
      }
    },
    {
      "id": "supervise",
      "name": "Supervise",
      "category": "governance",
      "description": "Quality gate: verify output matches prompt, send to testers, handle pass/fail, merge or reassign with WHY + WHAT TO FIX notes",
      "runner": "runners/supervise.py",
      "inputs": ["task_id", "completed_output", "tester_result"],
      "outputs": ["quality_check", "action", "reassignment_packet"],
      "ok_probe": {
        "command": "python runners/supervise.py --probe",
        "timeout_seconds": 10
      }
    },
    {
      "id": "execute_courier",
      "name": "Courier Execution",
      "category": "execution",
      "description": "Execute tasks on web AI platforms (ChatGPT, Claude, Gemini web). Returns chat_url for revisions.",
      "runner": "runners/courier.py",
      "inputs": ["task_packet"],
      "outputs": ["result", "chat_url", "model_name", "tokens_used"],
      "ok_probe": {
        "command": "python runners/courier.py --probe",
        "timeout_seconds": 30
      }
    },
    {
      "id": "execute_internal_cli",
      "name": "Internal CLI Execution",
      "category": "execution",
      "description": "Execute tasks via CLI tools (Kimi, OpenCode). Has codebase access.",
      "runner": "runners/internal_cli.py",
      "inputs": ["task_packet", "codebase_files"],
      "outputs": ["result", "model_name", "tokens_used"],
      "ok_probe": {
        "command": "python runners/internal_cli.py --probe",
        "timeout_seconds": 15
      }
    },
    {
      "id": "execute_internal_api",
      "name": "Internal API Execution",
      "category": "execution",
      "description": "Execute tasks via API (DeepSeek, Gemini API). Has codebase access.",
      "runner": "runners/internal_api.py",
      "inputs": ["task_packet", "codebase_files"],
      "outputs": ["result", "model_name", "tokens_used", "cost"],
      "ok_probe": {
        "command": "python runners/internal_api.py --probe",
        "timeout_seconds": 15
      }
    },
    {
      "id": "test_code",
      "name": "Code Testing",
      "category": "validation",
      "description": "Run unit tests, integration tests, lint, typecheck on generated code",
      "runner": "runners/test_code.py",
      "inputs": ["files", "test_type"],
      "outputs": ["pass_fail", "coverage", "errors"],
      "ok_probe": {
        "command": "python runners/test_code.py --probe",
        "timeout_seconds": 20
      }
    },
    {
      "id": "test_visual",
      "name": "Visual Testing",
      "category": "validation",
      "description": "Visual regression testing for UI components",
      "runner": "runners/test_visual.py",
      "inputs": ["component", "baseline"],
      "outputs": ["diff", "approval"],
      "ok_probe": {
        "command": "python runners/test_visual.py --probe",
        "timeout_seconds": 30
      }
    },
    {
      "id": "research",
      "name": "Research",
      "category": "maintenance",
      "description": "Research topics, technologies, best practices. Returns synthesized findings.",
      "runner": "runners/research.py",
      "inputs": ["query", "depth"],
      "outputs": ["summary", "sources", "recommendations"],
      "ok_probe": {
        "command": "python runners/research.py --probe",
        "timeout_seconds": 20
      }
    },
    {
      "id": "report",
      "name": "Report",
      "category": "maintenance",
      "description": "Generate reports, briefings, ROI analysis, status updates for human",
      "runner": "runners/report.py",
      "inputs": ["report_type", "time_range", "filters"],
      "outputs": ["report", "metrics"],
      "ok_probe": {
        "command": "python runners/report.py --probe",
        "timeout_seconds": 15
      }
    },
    {
      "id": "system_update",
      "name": "System Update",
      "category": "maintenance",
      "description": "ONLY agent allowed to touch system. Implements changes after Council + Supervisor approval. Sandbox tests everything.",
      "runner": "runners/maintenance.py",
      "inputs": ["change_request", "approvals", "sandbox_test_plan"],
      "outputs": ["implementation_status", "test_results", "rollback_plan"],
      "requires_approval": ["council", "supervisor"],
      "approval_chain": {
        "researcher": "suggests",
        "maintenance": "evaluates",
        "council": "reviews",
        "supervisor": "approves",
        "maintenance": "implements"
      },
      "ok_probe": {
        "command": "python runners/maintenance.py --probe",
        "timeout_seconds": 10
      }
    }
  ]
}
