# VibePilot Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# =============================================================================
# BOOTSTRAP KEYS (Only 3 needed - all others come from Vault)
# =============================================================================

# Supabase project URL
# Find at: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/service role key
# Find at: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_KEY=your-supabase-key-here

# Vault encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# STORE THIS SECURELY - it encrypts all your API keys
VAULT_KEY=your-vault-key-here

# =============================================================================
# VAULT STORED SECRETS (Managed via vault_manager.py)
# =============================================================================
# These are NOT in .env - they're encrypted in Supabase secrets_vault table
# To add a secret:
#   from vault_manager import VaultManager
#   vault = VaultManager()
#   vault.ingest_secret('DEEPSEEK_API_KEY', 'your-key-here')
#
# Currently in vault:
#   - DEEPSEEK_API_KEY
#   - GITHUB_TOKEN
#   - GEMINI_API_KEY (to be added)
#
# To retrieve:
#   key = vault.get_secret('DEEPSEEK_API_KEY')

# =============================================================================
# CLI-BASED MODELS (No API key needed)
# =============================================================================
# Kimi: Uses ~/.kimi/ auth (kimi-cli subscription)
# GLM: Uses OpenCode subscription (you're reading this through it)

# =============================================================================
# MIGRATION INSTRUCTIONS
# =============================================================================
# 1. Store these 3 keys in GitHub Secrets:
#    - SUPABASE_URL
#    - SUPABASE_KEY
#    - VAULT_KEY
#
# 2. On new machine:
#    git clone git@github.com:VibesTribe/VibePilot.git
#    cd VibePilot
#    # Set the 3 env vars (from GitHub Secrets or manually)
#    export SUPABASE_URL=...
#    export SUPABASE_KEY=...
#    export VAULT_KEY=...
#    ./setup.sh
#
# 3. Vault automatically available - all API keys retrieved on demand
#
