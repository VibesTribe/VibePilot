# VibePilot Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# =============================================================================
# SUPABASE (Required - Primary Database)
# =============================================================================

# Supabase project URL
# Find at: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/service role key
# Find at: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# Use service_role key for backend, anon key for frontend
SUPABASE_KEY=your-supabase-key-here

# =============================================================================
# AI MODELS (Required for multi-model orchestration)
# =============================================================================

# GLM-5 API Key (Primary coder/planner)
# Get at: https://open.bigmodel.cn/
GLM_API_KEY=your-glm-api-key-here

# DeepSeek API Key (Backup model)
# Get at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Kimi API Key (Parallel executor)
# Get at: https://kimi.moonshot.cn/
KIMI_API_KEY=your-kimi-api-key-here

# =============================================================================
# GITHUB (Required for code management)
# =============================================================================

# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Needs: repo, read:org, read:user scopes
GITHUB_TOKEN=your-github-token-here

# =============================================================================
# OPTIONAL (Future integrations)
# =============================================================================

# Gemini API Key (Research/Council) - Currently rate-limited free tier
# GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API Key (If using ChatGPT via Courier)
# OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API Key (If using Claude via Courier)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# =============================================================================
# NOTES
# =============================================================================
# 
# Model Priority:
#   1. GLM-5: Primary (coder, planner, supervisor)
#   2. Kimi: Parallel executor, attack reviewer
#   3. Gemini: Research, Council (limited free tier)
#   4. DeepSeek: Backup
#
# If migrating to new server:
#   1. Copy this file to .env
#   2. Fill in values
#   3. Run ./setup.sh
#
# Security:
#   - Never commit .env to git
#   - Rotate keys if accidentally exposed
#   - Use minimal required scopes for GitHub token
#
