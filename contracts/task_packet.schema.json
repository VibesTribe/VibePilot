{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VibePilot Task Packet",
  "type": "object",
  "required": [
    "task_id",
    "task_number",
    "title",
    "objectives",
    "deliverables",
    "confidence",
    "output_requirements"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "description": "Unique task identifier (UUID)"
    },
    "task_number": {
      "type": "string",
      "pattern": "^T[0-9]{3}$",
      "description": "Human-readable task number (T001, T002, etc.)"
    },
    "title": {
      "type": "string",
      "description": "Short task title"
    },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "description": "What this task accomplishes"
    },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "description": "Files to create/modify"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.95,
      "maximum": 1,
      "description": "Planner confidence score (must be >= 0.95)"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "task_id": {"type": "string"},
          "type": {"type": "string", "enum": ["code_context", "summary", "none"]}
        }
      },
      "description": "Tasks this depends on"
    },
    "output_requirements": {
      "type": "object",
      "required": ["format", "fields"],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["json", "code", "markdown", "files"],
          "description": "Expected output format"
        },
        "fields": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Required fields in output"
        },
        "include_task_number": {
          "type": "boolean",
          "default": true,
          "description": "Output must include task_number"
        },
        "include_model": {
          "type": "boolean",
          "default": true,
          "description": "Output must include model that completed task"
        }
      }
    },
    "routing": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["internal", "courier"],
          "description": "Internal (CLI/API) or Courier (web platform)"
        },
        "requires_codebase": {
          "type": "boolean",
          "default": false,
          "description": "Needs codebase awareness"
        },
        "suggested_model": {
          "type": "string",
          "description": "Recommended model"
        },
        "courier_platform": {
          "type": "string",
          "enum": ["chatgpt", "claude", "gemini", "any"],
          "description": "For courier tasks, which platform"
        }
      }
    },
    "roi_tracking": {
      "type": "object",
      "properties": {
        "estimated_tokens_in": {
          "type": "integer",
          "description": "Estimated input tokens"
        },
        "estimated_tokens_out": {
          "type": "integer", 
          "description": "Estimated output tokens"
        },
        "complexity": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Task complexity rating"
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Checklist for completion"
    },
    "prompt_packet": {
      "type": "string",
      "description": "Full instructions for executor"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
