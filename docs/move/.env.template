# VibePilot Bootstrap Environment
# Copy this file to .env and fill in the values

# --- REQUIRED (3 keys to start) ---

SUPABASE_URL=https://qtpdzsinvifkgpxyxlaz.supabase.co
SUPABASE_KEY=<service-role-key-from-supabase-dashboard>
VAULT_KEY=<32-char-encryption-key-for-secrets-vault>

# --- HOW TO GET THESE ---

# SUPABASE_URL: 
#   Found in Supabase Dashboard > Settings > API > Project URL
#   Value: https://qtpdzsinvifkgpxyxlaz.supabase.co

# SUPABASE_KEY:
#   Found in Supabase Dashboard > Settings > API > service_role (secret)
#   WARNING: Keep this secret! It has full database access.

# VAULT_KEY:
#   This is the encryption key for the secrets_vault table.
#   Must be 32 characters. If you don't have it, you'll need to
#   regenerate the vault on the new server.

# --- WHAT HAPPENS AFTER ---

# Once these 3 are set, VibePilot can:
# 1. Connect to Supabase for tasks, config, state
# 2. Decrypt secrets from the vault (API keys, tokens)
# 3. Run autonomously via systemd

# All other secrets (GEMINI_API_KEY, DEEPSEEK_API_KEY, etc.)
# are stored in Supabase secrets_vault table, not in this file.
