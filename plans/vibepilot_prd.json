{
  "prd": {
    "version": "1.0",
    "title": "VibePilot - Self-Build",
    "overview": "Complete VibePilot system build. VibePilot is a sovereign AI execution engine that transforms user ideas into production applications through multi-agent coordination.",
    
    "project_type": "business",
    "existing_infrastructure": {
      "schema": "Supabase tables: tasks, task_packets, task_runs, models, platforms, projects, secrets_vault, council_reviews",
      "runners": "Kimi CLI (with swarm), API runners (DeepSeek, Gemini, OpenRouter)",
      "core": "ConcurrentOrchestrator, SupervisorAgent, TaskManager, VaultManager",
      "telemetry": "OpenTelemetry with fallback, LoopDetector",
      "memory": "Pluggable interface (FileBackend, SupabaseBackend)",
      "dependency_rpc": "Supabase functions for atomic task unlock"
