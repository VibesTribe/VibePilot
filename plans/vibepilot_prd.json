            "POST /api/tasks - create task",
            "GET /api/runners - runner status",
            "GET /api/roi - ROI report"
          ]
        }
      ],
      
      "p1_important": [
        {
          "name": "Visual Tester Implementation",
          "description": "Browser-based visual testing using browser-use",
