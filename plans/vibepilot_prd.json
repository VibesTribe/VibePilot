    "architecture": {
      "existing_components": [
        "core/orchestrator.py - ConcurrentOrchestrator, RunnerPool, DependencyManager",
        "core/telemetry.py - Telemetry, LoopDetector",
        "core/memory.py - Memory interface with backends",
        "agents/supervisor.py - SupervisorAgent",
        "task_manager.py - TaskManager",
        "vault_manager.py - VaultManager",
        "runners/kimi_runner.py - KimiRunner with swarm",
        "runners/api_runner.py - DeepSeek, Gemini, OpenRouter runners"
      ],
      "needed_components": [
        "api/server.py - FastAPI REST endpoints",
        "agents/consultant.py - Consultant implementation",
        "agents/planner.py - Planner implementation",
        "agents/council.py - Council implementation",
        "agents/tester_code.py - Code tester implementation",
        "agents/tester_visual.py - Visual tester implementation",
        "agents/watcher.py - Watcher implementation",
        "agents/researcher.py - System researcher implementation",
        "agents/maintenance.py - Maintenance implementation",
        "agents/courier.py - Courier (Phase 3)",
        "voice/interface.py - Voice control (Phase 3)",
        "cli/vibepilot.py - CLI tool"
      ],
      "data_flow": "User → Consultant → PRD → Planner → Tasks → Council → Orchestrator → Runners → Supervisor → Tester → Merge → User Repo"
    },
    
    "tech_stack": {
      "language": "python",
      "framework": "fastapi",
      "database": "supabase",
      "testing": "pytest",
      "frontend": "react + typescript (dashboard)",
      "browser_automation": "browser-use",
      "voice": "whisper + elevenlabs (future)"
    },
    
    "security_requirements": [
      "All secrets in vault (never in code)",
      "API endpoints require auth",
      "Rate limiting on all endpoints",
      "No secrets in logs or telemetry"
    ],
    
    "edge_cases": [
      "Task fails after max attempts → escalate to human",
      "Runner unavailable → try next best",
      "Context limit hit → graceful degradation",
      "Supabase connection lost → retry with backoff"
    ],
    
    "out_of_scope": [
      "Mobile app for VibePilot",
      "Multi-tenant (one user for now)",
      "Payment processing"
    ]
